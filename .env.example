# Copy to `.env` and fill in secrets. Never commit `.env` or service-account JSON.

# --- Discord (required) ---
# Bot login to Discord (“서버 로그인”) — set in .env only; never commit the real value
TOKEN=your_discord_bot_token

# --- Roles / channels (optional overrides; defaults in src/config/constants.js) ---
WORKING_ROLE_ID=
OWNER_IDS=
GUEST_ROLE_ID=
DAYOFF_CHANNEL_ID=
DAYOFF_REVIEWER_ID=
PURCHASE_OWNER_DM_IDS=
LIVE_EXCEPTION_MANAGER_ROLE_IDS=
ANNOUNCEMENT_MANAGER_ROLE_IDS=

# --- Google service account key ---
# Master copy is often kept outside the repo, e.g.:
#   C:/Users/<you>/Downloads/sheet-bot-key.json
# Both vars point at the same file so index.js and scripts/ stay aligned.
PURCHASE_GOOGLE_KEY_FILE=C:/Users/hyun yong/Downloads/sheet-bot-key.json
GOOGLE_APPLICATION_CREDENTIALS=C:/Users/hyun yong/Downloads/sheet-bot-key.json

# --- Google Sheets (two workbooks) ---
# Work list — Paagrio Great / Heine Great (live 3-day source)
PURCHASE_SPREADSHEET_ID=1oScjqyvV0EHZffLYxZL4fI_pLVr7R2ABvLv7n-_gJTk
# 급여토탈관리 — 최근_3일_요약 / 월간_누적_요약 (formulas pull from Work list)
PAYROLL_SUMMARY_SPREADSHEET_ID=1IFZ-oBqatX0cEN7k7JiUr_UkqyAoXPi2LgmEifNG0eY
# 급여토탈관리 — Raw_Data + Discord /급여기록 (reads Great from PURCHASE_SPREADSHEET_ID)
PAYROLL_ARCHIVE_SPREADSHEET_ID=1IFZ-oBqatX0cEN7k7JiUr_UkqyAoXPi2LgmEifNG0eY
PAYROLL_SYNC_WORKLIST_SUMMARY=false
ALLOW_WORKLIST_PAYROLL_WRITES=0
# Legacy alias (optional): same as PURCHASE_SPREADSHEET_ID
SPREADSHEET_ID=

# --- Apps Script web app for raw attendance (HTTP fallback / profile sync) ---
# Must end with /exec — redeploy Apps Script after Code.js changes, then update here.
RAW_ATTENDANCE_WEBAPP_URL=

# --- Payroll automation (bot cron) ---
# Auto /급여기록 when last record + PAYROLL_AUTO_ARCHIVE_HOURS (default 75). Check every 6h.
PAYROLL_AUTO_ARCHIVE_ENABLED=true
PAYROLL_AUTO_ARCHIVE_HOURS=75
# 연속 N회 3일 sync 실패 시 서버주인 DM (기본 3, 알림 간격 ms 기본 30분)
PAYROLL_LIVE_SYNC_ALERT_THRESHOLD=3
PAYROLL_LIVE_SYNC_ALERT_COOLDOWN_MS=1800000

# Heartbeat: attendance (voice/dashboard) vs maintenance (backup/ops) — ms
HEARTBEAT_ATTENDANCE_MS=60000
HEARTBEAT_MAINTENANCE_MS=300000

# Checklist (no live API calls): npm run ops:google-check

# Purchase sheet layout (tab + section labels)
PURCHASE_HEINE_TAB_NAME=
PURCHASE_PAAGRIO_TAB_NAME=
PURCHASE_DAY_SECTION_LABEL=
PURCHASE_NIGHT_SECTION_LABEL=

# Comma-separated alias map: discordName=sheetName,other=alias
SHEET_NAME_ALIASES=

# --- Purchase / penalties (optional) ---
PURCHASE_CHANNEL_ID=
PURCHASE_CHANNEL_NAME=
PURCHASE_APPROVAL_EMOJI=
PURCHASE_CANCEL_EMOJI=
PURCHASE_UNIT_PRICE=
DEATH_PENALTY_AMOUNT=
DEATH_PENALTY_PAAGRIO_CHANNEL_ID=
DEATH_PENALTY_HEINE_CHANNEL_ID=
DEATH_PENALTY_REVIEWER_ROLE_IDS=
END_ADENA_PAAGRIO_CHANNEL_ID=
END_ADENA_HEINE_CHANNEL_ID=
END_ADENA_REVIEWER_ROLE_IDS=

SHARED_SEAT_USER_ID=
